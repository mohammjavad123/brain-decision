# ---- LLM provider (the brain is provider-agnostic — only src/llm/structured.ts knows the difference) ----
# 'openai' (default) or 'gemini'. Gemini uses its OpenAI-compatible endpoint, so no code changes.
LLM_PROVIDER=gemini

# ---- Keys: set the ONE that matches LLM_PROVIDER ----
# Powers the LLM seams: extract · compose · refine · assess · synthesize. Nothing LLM runs without it.
GEMINI_API_KEY=
OPENAI_API_KEY=

# ---- Embeddings (write-time clustering + question routing) — local & free by default ----
# 'local'  = transformers.js, all-mpnet-base-v2 (768-dim). No key. Downloads ~110MB once. (default)
# 'openai' = text-embedding-3-small (1536-dim), reuses OPENAI_API_KEY.
EMBEDDING_PROVIDER=local
# LOCAL_EMBED_MODEL=Xenova/all-mpnet-base-v2

# ---- Models (optional; sensible per-provider defaults are auto-selected) ----
# On Gemini: cheap/fast Flash for high-volume seams, Pro for the reasoning seams.
EXTRACT_MODEL=gemini-2.5-flash
COMPOSE_MODEL=gemini-2.5-pro
ANSWER_MODEL=gemini-2.5-flash        # refine + assess (fast, high-volume)
# SYNTHESIZE_MODEL=gemini-2.5-pro    # the decision point (deep reconcile/staleness reasoning)

# ---- (Phase 2, optional) Web research for gap-filling ----
# Used by the agent's `research` node. Without it, research degrades honestly (the brain says so).
TAVILY_API_KEY=
